{
  "name": "mcp-configurator",
  "version": "0.1.0",
  "description": "Cross-platform Electron + React app for configuring MCP servers for Claude Desktop and Gemini CLI.",
  "private": true,
  "license": "MIT",
  "main": "dist-electron/main/electron-main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup src/main/electron-main.ts src/preload/electron-preload.ts --format=cjs --out-dir dist-electron --watch --sourcemap",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron-main.js file:dist-electron/electron-preload.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup src/main/electron-main.ts src/preload/electron-preload.ts --format=cjs --out-dir dist-electron --sourcemap",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac dmg --publish never",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "package:linux": "npm run build && electron-builder --linux AppImage deb --publish never"
  },
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.sarvesh.mcpconfigurator",
    "productName": "MCP Configurator",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
